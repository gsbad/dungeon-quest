  "version": "0.0.1",
  "configurations": [
    {
      "name": "pygbag-pc",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "pygbag", "--bind", "localhost", "--port", "8000", "main.py"],
      "port": 8000
