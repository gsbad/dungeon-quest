<body>

    <!-- Stage K23: forced login gate - see the CSS block above for the
         visual reasoning. Google's Identity Services library allows more
         than one .g_id_signin button on the same page sharing one
         data-callback (dqHandleCredential further down), so this reuses the
         exact same login plumbing #dq-auth-bar already had rather than
         inventing a second auth path. Starts visible (no inline style) -
         the very next script block below hides it synchronously (before
         paint, since it's a plain synchronous <script>, not async/defer)
         for the two cases that should skip it entirely: local/LAN dev, or
         a returning visitor who already has a JWT in localStorage. -->
    <div id="dq-login-gate">
        <div class="dq-gate-box">
            <h1>{{cookiecutter.title}}</h1>
            <p>Faca login com sua conta Google para continuar.</p>
            <div class="g_id_signin" data-type="standard" data-size="large" data-shape="pill"></div>
            <div id="dq-gate-error"></div>
        </div>
    </div>
    <script>
        // Stage K23: kept deliberately separate from the g_id_onload/
        // dqHandleCredential wiring further down the page (after the GSI
        // library's own script tag loads) - this only needs to decide
        // whether the gate should even be shown, which doesn't depend on
        // GSI being loaded yet.
        function dqIsLocalOrLan() {
            const h = location.hostname;
            return h === "localhost" || h === "127.0.0.1" ||
                   /^192\.168\.\d{1,3}\.\d{1,3}$/.test(h) ||
                   /^10\.\d{1,3}\.\d{1,3}\.\d{1,3}$/.test(h) ||
                   /^172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}$/.test(h);
        }
        if (dqIsLocalOrLan() || localStorage.getItem("dungeon_quest_jwt")) {
            document.getElementById("dq-login-gate").style.display = "none";
        }
    </script>

    <!-- CUSTOM (Stage I2): login bar, a sibling of #transfer/#canvas, not a
         child of #transfer - #transfer is hidden almost immediately by
         pygbag's own bootstrap (see custom_site() near the top of this
         file), so anything placed inside it (an earlier stub comment here
         suggested that) would barely be visible before disappearing. This
         bar stays up through loading and gameplay alike. -->
    <div id="dq-auth-bar">
        <span id="dq-auth-status">Nao conectado</span>
        <!-- data-client_id is set from window.DQ_GOOGLE_CLIENT_ID by the
             script below, not hardcoded here. -->
        <div id="g_id_onload"
             data-callback="dqHandleCredential"
             data-auto_select="true"></div>
        <div class="g_id_signin" id="dq-google-btn" data-type="standard" data-size="small" data-shape="pill"></div>
        <button id="dq-signout" hidden>Sair</button>
    </div>

    <script>
        // g_id_onload's data-client_id can't read window.DQ_GOOGLE_CLIENT_ID
        // directly (it's a static HTML attribute) - set it here instead of
        // hardcoding the Client ID a second time in this file.
        document.getElementById("g_id_onload").setAttribute("data-client_id", window.DQ_GOOGLE_CLIENT_ID);

        function dqSetStatus(text) {
            document.getElementById("dq-auth-status").textContent = text;
        }

        function dqApplySession(jwt, email) {
            dqSetStatus(email ? ("Conectado: " + email) : "Conectado");
            document.getElementById("dq-google-btn").hidden = true;
            document.getElementById("dq-signout").hidden = false;
            // Stage K23: covers the fresh-login-this-visit case - a
            // returning visitor with an already-stored JWT never reaches
            // here at all, the synchronous bypass script right after
            // #dq-login-gate's markup already hid it before this ever ran.
            const gate = document.getElementById("dq-login-gate");
            if (gate) gate.style.display = "none";
        }

        // Google's credential callback (data-callback above). Same pattern
        // game/save.py already uses for the save blob: localStorage is the
        // single source of truth, not a window global that dies on reload -
        // game/net.py (Python side) reads "dungeon_quest_jwt" straight out
        // of localStorage, it never touches a window global at all.
        async function dqHandleCredential(response) {
            try {
                const res = await fetch(window.DQ_API_BASE + "/auth/google", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id_token: response.credential }),
                });
                if (!res.ok) {
                    dqSetStatus("Falha no login");
                    dqSetGateError("Falha no login. Tente novamente.");
                    return;
                }
                const data = await res.json();
                localStorage.setItem("dungeon_quest_jwt", data.jwt);
                localStorage.setItem("dungeon_quest_email", data.email);
                dqApplySession(data.jwt, data.email);
            } catch (e) {
                console.warn("dqHandleCredential failed:", e);
                dqSetStatus("Backend indisponivel");
                // Stage K23: the gate has no bypass for "backend is down" -
                // a visitor stuck here at least sees why instead of a
                // button that silently does nothing every time it's clicked.
                dqSetGateError("Servidor de login indisponivel no momento.");
            }
        }

        function dqSetGateError(text) {
            const el = document.getElementById("dq-gate-error");
            if (el) el.textContent = text;
        }

        document.getElementById("dq-signout").addEventListener("click", () => {
            localStorage.removeItem("dungeon_quest_jwt");
            localStorage.removeItem("dungeon_quest_email");
            dqSetStatus("Nao conectado");
            document.getElementById("dq-google-btn").hidden = false;
            document.getElementById("dq-signout").hidden = true;
        });

        // Returning visitor: a JWT already in localStorage from a previous
        // page load means the player is still "logged in" without touching
        // the Google button again.
        (function dqRestoreSession() {
            const jwt = localStorage.getItem("dungeon_quest_jwt");
            const email = localStorage.getItem("dungeon_quest_email");
            if (jwt) dqApplySession(jwt, email);
        })();
    </script>

