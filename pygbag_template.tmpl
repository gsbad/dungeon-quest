    <script>
    // CUSTOM: force the canvas to a real 800x600 (4:3) box, computed in JS
    // rather than pure CSS. pygbag's own window_resize() (from its core JS
    // bundle, loaded separately) sets canvas.style.width/height directly,
    // which is an *inline* style and overrides any CSS class rule
    // (including the aspect-ratio one added above) - so a CSS-only fix
    // isn't enough here. This runs after load, on every window resize, and
    // repeatedly for a few seconds after load to win against any late
    // resize call from pygbag's own runtime.
    (function() {
        var LOGICAL_W = 800, LOGICAL_H = 600, RATIO = LOGICAL_W / LOGICAL_H;

        function fitCanvas() {
            var c = document.getElementById('canvas');
            if (!c) {
                return;
            }
            var vw = window.innerWidth, vh = window.innerHeight;
            var w, h;
            if (vw / vh > RATIO) {
                h = vh; w = h * RATIO;
            } else {
                w = vw; h = w / RATIO;
            }
            c.style.width = w + 'px';
            c.style.height = h + 'px';
            c.style.position = 'absolute';
            c.style.left = ((vw - w) / 2) + 'px';
            c.style.top = ((vh - h) / 2) + 'px';
        }

        window.addEventListener('resize', fitCanvas);
        window.addEventListener('load', fitCanvas);
        fitCanvas();

        var tries = 0;
        var reassert = setInterval(function() {
            fitCanvas();
            if (++tries > 40) clearInterval(reassert); // ~12s of re-asserting, then stop
        }, 300);

        // CUSTOM: the canvas now reliably keeps a 4:3 shape, but it's still
        // *displayed* larger than its 800x600 internal buffer (e.g. 1215x911)
        // - and SDL2/emscripten isn't rescaling mouse event.pos for that
        // difference (confirmed by direct testing: clicks land far from the
        // button drawn there, in both distorted and aspect-correct cases).
        // Computing the correct canvas-buffer-relative coordinates here in
        // JS - where clientX/clientY and getBoundingClientRect() are exact -
        // and exposing them as globals is unambiguous, unlike guessing the
        // right Python-side scale factor. game/input_system.py reads these
        // via the platform/js bridge (same pattern as the localStorage spike)
        // instead of trusting event.pos under emscripten.
        function updateLogicalMouse(e) {
            var c = document.getElementById('canvas');
            if (!c) return;
            var rect = c.getBoundingClientRect();
            window.dqMouseLogicalX = (e.clientX - rect.left) * (c.width / rect.width);
            window.dqMouseLogicalY = (e.clientY - rect.top) * (c.height / rect.height);
        }
        window.addEventListener('mousedown', updateLogicalMouse, true);
        window.addEventListener('mousemove', updateLogicalMouse, true);
        window.addEventListener('mouseup', updateLogicalMouse, true);
    })();
    </script>

